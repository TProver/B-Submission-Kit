<externalTool name="BSKConnect"
              category="project"
              label="Connect"
              menu="BSK Submission"
              shortcut="Ctrl+Alt+C"
              tooltip="Connect this workstation to the classroom submission server"
              icon="bsk_logo.png">
    <command>"${extensionsDir}\bsk_run.cmd"</command>
    <param>connect</param>
    <param>${projectName}</param>
    <param>${projectBdp}</param>
</externalTool>
